# AICostCutters — VS Code Extension Configuration
# Forked from Kilo Code (https://github.com/Kilo-Org/kilocode)

# Extension identity
VSCODE_EXTENSION_NAME=aicostcutters
VSCODE_EXTENSION_DISPLAY_NAME=AICostCutters
VSCODE_EXTENSION_PUBLISHER=alexymarketplace

# Build
VSCODE_EXTENSION_VERSION=7.3.22
VSCODE_EXTENSION_VSCode_ENGINE=^1.105.1

# VS Code Marketplace
# To publish: npx vsce publish --pat <token>
# Marketplace URL: https://marketplace.visualstudio.com/manage/publishers/alexymarketplace

# Core feature
# Every first message in a chat session prompts the user with a sobriety check
# ("Are you drunk?") before the message is sent to the AI model.
# See: packages/opencode/src/cli/cmd/tui/component/prompt/index.tsx
